# -----------------------------------------------------------------------------
# ship.sh — .env template (preset: steam-mac)
#
# Steam Direct Distribution build: Developer ID signed, hardened runtime,
# notarized, ZIP packaged for Steamworks upload, Steam dylib + entitlements
# staged. Game Center is not available on this channel (AMFI rejects it on
# Developer-ID-signed Mac apps).
#
# Copy to .env, fill in the required signing values below, run ship.sh.
# Full reference: docs/configuration.md
# -----------------------------------------------------------------------------

# --- Preset values (baked in for steam-mac) ---
MAC_DISTRIBUTION="developer-id"
ENABLE_STEAM="1"
ENABLE_ZIP="1"
NOTARIZE="yes"

# --- Required for non-interactive runs ---
# DEVELOPMENT_TEAM="ABCDE12345"
# SIGN_IDENTITY="Developer ID Application: Your Company (ABCDE12345)"
# NOTARY_PROFILE="MyNotaryProfile"
# EXPORT_PLIST="/absolute/path/to/ExportOptions.plist"
# XCODE_SCHEME="MyGame"
# BUILD_TYPE="shipping"

# --- Steam (commonly customized) ---
# STEAM_APP_ID="480"
# WRITE_STEAM_APPID="0"
# STEAM_DYLIB_SRC="/absolute/path/to/libsteam_api.dylib"

# Auto-bumped Info.plist build counter; persisted to this file on success.
CFBUNDLE_VERSION="0"
