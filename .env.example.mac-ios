# -----------------------------------------------------------------------------
# ship.sh — .env template (preset: mac-ios)
#
# Direct Distribution Mac + iOS App Store build. Mac is signed/notarized/
# packaged via Developer ID; iOS is built and (optionally) uploaded to App
# Store Connect. CFBUNDLE_VERSION is shared across both platforms.
#
# Copy to .env, fill in the required values below, run ship.sh.
# Full reference: docs/configuration.md
# -----------------------------------------------------------------------------

# --- Preset values (baked in for mac-ios) ---
MAC_DISTRIBUTION="developer-id"
IOS_DISTRIBUTION="app-store"

# --- Mac (Developer ID) required values ---
# DEVELOPMENT_TEAM="ABCDE12345"
# SIGN_IDENTITY="Developer ID Application: Your Company (ABCDE12345)"
# NOTARY_PROFILE="MyNotaryProfile"
# EXPORT_PLIST="/absolute/path/to/ExportOptions.plist"
# XCODE_SCHEME="MyGame"
# BUILD_TYPE="shipping"
# NOTARIZE="yes"

# --- iOS required values ---
# IOS_EXPORT_PLIST="/absolute/path/to/iOS-ExportOptions.plist"
# IOS_SCHEME="MyGame"

# --- iOS App Store Connect upload (xcrun altool — NOT notarytool) ---
# IOS_ASC_VALIDATE="1"
# IOS_ASC_UPLOAD="1"
# ASC_API_KEY_ID="ABCD123456"
# ASC_API_ISSUER="00000000-0000-0000-0000-000000000000"
# ASC_API_KEY_PATH="/path/to/AuthKey_ABCD123456.p8"

# Auto-bumped Info.plist build counter; persisted to this file on success.
CFBUNDLE_VERSION="0"
