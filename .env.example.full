# -----------------------------------------------------------------------------
# ship.sh — .env template (full reference)
#
# Lists every supported variable. Copy to .env and uncomment what you need;
# most values are auto-detected or have sensible defaults.
#
# For preset-specific starter templates, see:
#   .env.example.steam-mac    Steam Direct Distribution (Developer ID, ZIP, notarized)
#   .env.example.direct-mac   Direct Distribution download (Developer ID, DMG, notarized)
#   .env.example.mas-mac      Mac App Store
#   .env.example.ios          iOS App Store only (Mac skipped)
#   .env.example.mac-ios      Direct Mac + iOS App Store
#   .env.example.mas-ios      Mac App Store + iOS App Store
#
# Full prose reference: docs/configuration.md
# CLI flag reference:   ./ship.sh --help all
#
# This file is sourced as shell code. Only use a .env file you trust.
# Quote values containing spaces. CLI flags override .env values.
# -----------------------------------------------------------------------------

# --- Signing & notarization (required for non-interactive Developer ID runs) ---
# DEVELOPMENT_TEAM="ABCDE12345"
# SIGN_IDENTITY="Developer ID Application: Your Company (ABCDE12345)"
# NOTARY_PROFILE="MyNotaryProfile"
# EXPORT_PLIST="/absolute/path/to/ExportOptions.plist"
# ENTITLEMENTS_FILE="/absolute/path/to/entitlements.plist"

# --- Project paths (usually auto-detected) ---
# REPO_ROOT="/absolute/path/to/project/root"
# UPROJECT_PATH="/absolute/path/to/MyGame.uproject"
# UPROJECT_NAME="MyGame.uproject"
# XCODE_WORKSPACE="MyGame (Mac).xcworkspace"
# XCODE_SCHEME="MyGame"

# --- Unreal Engine location ---
# UE_ROOT="/Users/Shared/Epic Games/UE_5.x"
# UAT_SCRIPTS_SUBPATH="Engine/Build/BatchFiles"
# UE_EDITOR_SUBPATH="Engine/Binaries/Mac/UnrealEditor.app/Contents/MacOS/UnrealEditor"

# --- Naming & output ---
# SHORT_NAME="MyGame"
# LONG_NAME="MyGame"
# BUILD_DIR_REL="BuildArtifacts/Mac"
# LOG_DIR_REL="Saved/Logs"

# --- Behavior (skip interactive prompts) ---
# BUILD_TYPE="shipping"        # shipping | development
# NOTARIZE="yes"               # yes | no
# DRY_RUN="0"
# PRINT_CONFIG="0"
# CLEAN_BUILD_DIR="0"
# USE_XCODE_EXPORT="1"
# REGEN_PROJECT_FILES="1"

# --- Distribution channels ---
# MAC_DISTRIBUTION="developer-id"   # developer-id | app-store | off
# IOS_DISTRIBUTION="off"            # off | app-store

# --- Bundle metadata ---
# MARKETING_VERSION="1.0.0"
# APP_CATEGORY="public.app-category.games"
# ENABLE_GAME_MODE="1"
# ENABLE_GAME_CENTER="1"            # iOS App Store + Mac App Store only

# --- CFBundleVersion (auto-bumped integer; persisted on success) ---
# Set a new baseline at runtime with: ./ship.sh --set-cfbundle-version N
CFBUNDLE_VERSION="0"
# USE_UE_PACKAGE_VERSION_COUNTER="0"   # Path A (opt-in): UE-canonical mechanism

# --- Version stamp (Content/<dir>/version.txt) ---
# VERSION_MODE="NONE"          # NONE | MANUAL | HYBRID | DATETIME
# VERSION_STRING="1.0.0"
# VERSION_CONTENT_DIR="BuildInfo"

# --- Steam (developer-id channel only) ---
# ENABLE_STEAM="0"
# STEAM_APP_ID="480"
# WRITE_STEAM_APPID="0"
# STEAM_DYLIB_SRC="/absolute/path/to/libsteam_api.dylib"

# --- Packaging (developer-id channel only) ---
# ENABLE_ZIP="1"
# ENABLE_DMG="0"
# FANCY_DMG="0"
# DMG_NAME="MyGame.dmg"
# DMG_VOLUME_NAME="MyGame"
# DMG_OUTPUT_DIR="Build"

# --- iOS pipeline ---
# IOS_WORKSPACE="MyGame (iOS).xcworkspace"
# IOS_SCHEME="MyGame"
# IOS_EXPORT_PLIST="iOS-ExportOptions.plist"
# IOS_APPICON_SET_NAME="AppIcon"
# IOS_MARKETING_VERSION="1.2.0"

# --- Mac App Store (MAC_DISTRIBUTION=app-store) ---
# MAS_EXPORT_PLIST="MAS-ExportOptions.plist"
# MAS_ASC_VALIDATE="0"
# MAS_ASC_UPLOAD="0"

# --- App Store Connect API key (shared by iOS + Mac App Store uploads) ---
# ASC_API_KEY_ID="ABCD123456"
# ASC_API_ISSUER="00000000-0000-0000-0000-000000000000"
# ASC_API_KEY_PATH="/path/to/AuthKey_ABCD123456.p8"

# --- App icon override (auto-detected if unset) ---
# MACOS_APPICON_SET_NAME="AppIcon"

# --- Seed toggles (default: enabled; disable if you maintain these yourself) ---
# SEED_MAC_INFO_TEMPLATE_PLIST="1"
# SEED_APPLE_LAUNCHSCREEN_COMPAT="1"
