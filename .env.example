# -----------------------------------------------------------------------------
# ship.sh — .env template
#
# Usage:
#   1) Copy this file to: ./.env   (same folder as ship.sh)
#   2) Fill in values as needed.
#      (Many values are optional — the script auto-detects what it can.)
#   3) Run the script normally.
#
# Notes:
# - This file is sourced as shell code. Do not use untrusted .env files.
# - Quote values that contain spaces.
# - CLI flags are highest priority.
# -----------------------------------------------------------------------------

# --- Project paths (usually optional) ---
# If omitted, script may auto-detect when placed in project root.
# REPO_ROOT="/absolute/path/to/your/project/root"
# UPROJECT_PATH="/absolute/path/to/MyGame.uproject"   # optional; if set, it is used before any auto-detect
# UPROJECT_NAME="MyGame.uproject"        # optional; used if UPROJECT_PATH is not set
# XCODE_WORKSPACE="MyGame (Mac).xcworkspace"  # optional; script can locate/choose/generate workspaces interactively
# XCODE_SCHEME="MyGame"                       # optional; script can auto-detect interactively, but CI should set it

# --- Output folders (relative to REPO_ROOT) ---
# BUILD_DIR_REL="Build"
# LOG_DIR_REL="Logs"

# --- Naming ---
# SHORT_NAME="MyGame"
# LONG_NAME="MyGame"

# --- Behavior toggles ---
# USE_XCODE_EXPORT="1"     # 1 = use Xcode archive/export, 0 = skip Xcode
# CLEAN_BUILD_DIR="0"      # 1 = wipe Build dir, 0 = safer
# DRY_RUN="0"              # 1 = print plan then exit
# PRINT_CONFIG="0"         # 1 = print resolved config then exit

# --- Unreal Engine location ---
# UE_ROOT="/Users/Shared/Epic Games/UE_5.x"   # optional; script can auto-detect common EGL installs on macOS
# UAT_SCRIPTS_SUBPATH="Engine/Build/BatchFiles"
# UE_EDITOR_SUBPATH="Engine/Binaries/Mac/UnrealEditor.app/Contents/MacOS/UnrealEditor"

# --- Signing / notarization ---
# DEVELOPMENT_TEAM="ABCDE12345"   # required for Developer ID exports
# SIGN_IDENTITY="Developer ID Application: Your Company (ABCDE12345)"   # required for signing
# EXPORT_PLIST="/absolute/path/to/ExportOptions.plist"   # optional for interactive runs; script can auto-detect or offer to generate
# NOTARY_PROFILE="MyNotaryProfile"   # only needed if notarizing (notarytool keychain profile)
# ENTITLEMENTS_FILE="/absolute/path/to/entitlements.plist"   # optional; script auto-generates if not set

# --- Optional Steam support ---
# ENABLE_STEAM="0"
# STEAM_APP_ID="480"
# WRITE_STEAM_APPID="0"
# STEAM_DYLIB_SRC="/absolute/path/to/libsteam_api.dylib"

# --- Optional macOS app icon seeding ---
# Syncs a source-controlled .xcassets catalog into the build so the shipped
# .app uses your repo's icon rather than the engine-global one.
# MACOS_ICON_SYNC="1"   # 1 = enable icon seeding (default: 1), 0 = disable
# MACOS_ICON_XCASSETS="macOS-SourceControlled.xcassets"   # path to your .xcassets (relative to REPO_ROOT or absolute)
#                                                          # default: $REPO_ROOT/macOS-SourceControlled.xcassets
# MACOS_APPICON_SET_NAME="AppIcon"   # name of the *.appiconset to use (without suffix); auto-detected if unset

# --- Optional DMG output ---
# ENABLE_ZIP="1"   # 1 = create ZIP alongside the app (default: on when NOTARIZE=yes)
# ENABLE_DMG="0"
# FANCY_DMG="0"    # experimental; 1 = Finder-layout + Applications link drag-to-install DMG
#                  # NOTE: Finder layout persistence can be inconsistent on some systems.
#                  # NOTE: Requires GUI session + Finder Automation permission.
# DMG_NAME="MyGame.dmg"
# DMG_VOLUME_NAME="MyGame"
# DMG_OUTPUT_DIR="Build"

# --- Sample DMG config (explicit defaults) ---
# ENABLE_DMG="1"
# FANCY_DMG="0"
# DMG_NAME="MyGame.dmg"
# DMG_VOLUME_NAME="MyGame"
# DMG_OUTPUT_DIR="Build"

# --- Optional version.txt (runtime version stamp) ---
# Stamps Content/<VERSION_CONTENT_DIR>/version.txt before UAT runs so UAT
# bundles it automatically.  The file is reset to "dev" on every exit so the
# editor never sees a build-stamped string.
#
# Requires Config/DefaultGame.ini to have:
#   [/Script/UnrealEd.ProjectPackagingSettings]
#   +DirectoriesToAlwaysStageAsNonUFS=(Path="BuildInfo")
# The script adds this automatically if it is missing when VERSION_MODE != NONE.
#
# VERSION_MODE="NONE"          # NONE (default) | MANUAL | HYBRID | DATETIME
# VERSION_STRING="1.0.0"       # base version for MANUAL and HYBRID; supports vX.Y.Z or X.Y.Z
# VERSION_CONTENT_DIR="BuildInfo"   # subdirectory under Content/ (must stay under Content/)
#
# Mode output examples (with VERSION_STRING="1.2.3" and a git repo):
#   MANUAL   → 1.2.3
#   HYBRID   → 1.2.3-a1b2c3d   (base + git short hash)
#   DATETIME → 20260318-143022-a1b2c3d
#
# --bump-major / --bump-minor / --bump-patch can be passed at runtime to
# increment VERSION_STRING from this file without editing it.

# --- Optional Info.plist stamping via xcconfig ---
# The script updates Intermediate/ProjectFiles/XcconfigsMac/<project>.xcconfig
# before the Xcode archive so these values flow into Info.plist automatically.
# The xcconfig must already exist (i.e. GenerateProjectFiles has been run).
#
# MARKETING_VERSION="1.0.0"   # CFBundleShortVersionString — the user-visible version shown
#                              # in Finder / App Store / About dialogs.
#                              # Defaults to 1.0.0 with a warning if not set.
#                              # CURRENT_PROJECT_VERSION (CFBundleVersion) is set from
#                              # VERSION_STRING / VERSION_MODE automatically when versioning
#                              # is enabled.
#
# ENABLE_GAME_MODE="1"         # 1 = stamp LSSupportsGameMode + GCSupportsGameMode = YES
#                              # 0 = stamp them NO
#                              # Defaults to YES (1) with a warning if not set.
#                              # macOS Game Mode (Sonoma 14+) gives your app elevated
#                              # CPU/GPU priority when a controller is connected.
#                              # Keys are placed immediately after LSApplicationCategoryType.
#
# APP_CATEGORY="public.app-category.games"
#                              # Optional override for INFOPLIST_KEY_LSApplicationCategoryType.
#                              # If unset, the existing value in the xcconfig is preserved.
#                              # Full list of valid category identifiers:
#                              # https://developer.apple.com/documentation/bundleresources/information-property-list/lsapplicationcategorytype

# --- Non-interactive (skip prompts) ---
# BUILD_TYPE="shipping"   # shipping | development (or s/d)
# NOTARIZE="yes"          # yes | no

# --- CI minimal config (common) ---
# In non-interactive environments, set at least:
#   DEVELOPMENT_TEAM
#   SIGN_IDENTITY
#   EXPORT_PLIST   (or generate one in-repo ahead of time)
# And if notarizing:
#   NOTARY_PROFILE
