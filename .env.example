# -----------------------------------------------------------------------------
# ship.sh — .env template
#
# Copy this file to .env (same folder as ship.sh) and uncomment the values you
# need. This template lists the variables required for a non-interactive run;
# every other knob is documented in docs/configuration.md.
#
# Full variable reference: docs/configuration.md
# CLI flag reference:      ./ship.sh --help all
# Common presets:          ./ship.sh --list-presets
#
# This file is sourced as shell code. Only use a .env file you trust.
# Quote values containing spaces. CLI flags override .env values.
# -----------------------------------------------------------------------------

# Required for non-interactive runs:
# DEVELOPMENT_TEAM="ABCDE12345"
# SIGN_IDENTITY="Developer ID Application: Your Company (ABCDE12345)"
# NOTARY_PROFILE="MyNotaryProfile"
# EXPORT_PLIST="/absolute/path/to/ExportOptions.plist"
# XCODE_SCHEME="MyGame"
# BUILD_TYPE="shipping"
# NOTARIZE="yes"

# Auto-bumped Info.plist build counter; persisted to this file on success.
# Use --set-cfbundle-version N to set a new baseline (e.g. CI build number).
CFBUNDLE_VERSION="0"
