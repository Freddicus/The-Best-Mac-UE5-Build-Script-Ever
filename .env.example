# -----------------------------------------------------------------------------
# ship.sh — .env template
#
# Usage:
#   1) Copy this file to: ./.env   (same folder as ship.sh)
#   2) Fill in values as needed.
#      (Many values are optional — the script auto-detects what it can.)
#   3) Run the script normally.
#
# Notes:
# - This file is sourced as shell code. Do not use untrusted .env files.
# - Quote values that contain spaces.
# - CLI flags are highest priority.
# -----------------------------------------------------------------------------

# --- Project paths (usually optional) ---
# If omitted, script may auto-detect when placed in project root.
# REPO_ROOT="/absolute/path/to/your/project/root"
# UPROJECT_PATH="/absolute/path/to/MyGame.uproject"   # optional; if set, it is used before any auto-detect
# UPROJECT_NAME="MyGame.uproject"        # optional; used if UPROJECT_PATH is not set
# XCODE_WORKSPACE="MyGame (Mac).xcworkspace"  # optional; script can locate/choose/generate workspaces interactively
# XCODE_SCHEME="MyGame"                       # optional; script can auto-detect interactively, but CI should set it

# --- Output folders (relative to REPO_ROOT) ---
# Build/ is for committed source-controlled inputs (icons, launch storyboard,
# entitlements). Outputs live under Saved/ (UE convention). See docs/output.md.
# BUILD_DIR_REL="Saved/Packages/Mac"   # script-side outputs; UAT -archivedirectory derives from this
# LOG_DIR_REL="Saved/Logs"

# --- Naming ---
# SHORT_NAME="MyGame"
# LONG_NAME="MyGame"

# --- Behavior toggles ---
# USE_XCODE_EXPORT="1"      # 1 = use Xcode archive/export, 0 = skip Xcode
# REGEN_PROJECT_FILES="1"   # 1 = run GenerateProjectFiles.sh before xcodebuild
                            # (picks up new files under Build/{Platform}/Resources/)
# CLEAN_BUILD_DIR="0"       # 1 = wipe BUILD_DIR_REL before building, 0 = safer
# DRY_RUN="0"               # 1 = print plan then exit
# PRINT_CONFIG="0"          # 1 = print resolved config then exit

# --- Unreal Engine location ---
# UE_ROOT="/Users/Shared/Epic Games/UE_5.x"   # optional; script can auto-detect common EGL installs on macOS
# UAT_SCRIPTS_SUBPATH="Engine/Build/BatchFiles"
# UE_EDITOR_SUBPATH="Engine/Binaries/Mac/UnrealEditor.app/Contents/MacOS/UnrealEditor"

# --- Signing / notarization ---
# DEVELOPMENT_TEAM="ABCDE12345"   # required for Developer ID exports
# SIGN_IDENTITY="Developer ID Application: Your Company (ABCDE12345)"   # required for signing
# EXPORT_PLIST="/absolute/path/to/ExportOptions.plist"   # optional for interactive runs; script can auto-detect or offer to generate
# NOTARY_PROFILE="MyNotaryProfile"   # only needed if notarizing (notarytool keychain profile)
# ENTITLEMENTS_FILE="/absolute/path/to/entitlements.plist"   # optional; script auto-generates if not set

# --- Optional Steam support ---
# ENABLE_STEAM="0"
# STEAM_APP_ID="480"
# WRITE_STEAM_APPID="0"
# STEAM_DYLIB_SRC="/absolute/path/to/libsteam_api.dylib"

# --- Optional macOS app icon ---
# Maintain Build/Mac/Resources/Assets.xcassets/AppIcon.appiconset/ in your project
# (UE auto-discovers Build/<Platform>/Resources/Assets.xcassets via XcodeProject.cs:1731).
# If your appiconset is named something other than "AppIcon", set the override
# below and the script will mirror it to AppIcon.appiconset before regen.
# UE's xcconfig hardcodes ASSETCATALOG_COMPILER_APPICON_NAME=AppIcon, so the
# mirror is what makes actool find your icons.
# MACOS_APPICON_SET_NAME="AppIcon"   # auto-detected if unset

# --- Optional DMG output ---
# ENABLE_ZIP="1"   # 1 = create ZIP alongside the app (default: on when NOTARIZE=yes)
# ENABLE_DMG="0"
# FANCY_DMG="0"    # experimental; 1 = Finder-layout + Applications link drag-to-install DMG
#                  # NOTE: Finder layout persistence can be inconsistent on some systems.
#                  # NOTE: Requires GUI session + Finder Automation permission.
# DMG_NAME="MyGame.dmg"
# DMG_VOLUME_NAME="MyGame"
# DMG_OUTPUT_DIR="Build"

# --- Sample DMG config (explicit defaults) ---
# ENABLE_DMG="1"
# FANCY_DMG="0"
# DMG_NAME="MyGame.dmg"
# DMG_VOLUME_NAME="MyGame"
# DMG_OUTPUT_DIR="Build"

# --- Optional version.txt (runtime version stamp) ---
# Stamps Content/<VERSION_CONTENT_DIR>/version.txt before UAT runs so UAT
# bundles it automatically.  The file is reset to "dev" on every exit so the
# editor never sees a build-stamped string.
#
# Requires Config/DefaultGame.ini to have:
#   [/Script/UnrealEd.ProjectPackagingSettings]
#   +DirectoriesToAlwaysStageAsNonUFS=(Path="BuildInfo")
# The script adds this automatically if it is missing when VERSION_MODE != NONE.
#
# VERSION_MODE="NONE"          # NONE (default) | MANUAL | HYBRID | DATETIME
# VERSION_STRING="1.0.0"       # base version for MANUAL and HYBRID; supports vX.Y.Z or X.Y.Z
# VERSION_CONTENT_DIR="BuildInfo"   # subdirectory under Content/ (must stay under Content/)
#
# Mode output examples (with VERSION_STRING="1.2.3" and a git repo):
#   MANUAL   → 1.2.3
#   HYBRID   → 1.2.3-a1b2c3d   (base + git short hash)
#   DATETIME → 20260318-143022-a1b2c3d
#
# --bump-major / --bump-minor / --bump-patch can be passed at runtime to
# increment VERSION_STRING from this file without editing it.

# --- Info.plist values via canonical UE override paths ---
# The script writes these to UE's sanctioned locations (DefaultEngine.ini and
# Build/Mac/Resources/Info.Template.plist) so values are visible to you in
# committed config and survive every GenerateProjectFiles regeneration.
# See docs/versioning.md for the full mapping and rationale.
#
# MARKETING_VERSION="1.0.0"
#   When set, the script writes [/Script/MacRuntimeSettings.MacRuntimeSettings]
#   VersionInfo=<value> to Config/DefaultEngine.ini. UE reads it at regen time
#   and stamps it into CFBundleShortVersionString. Unset = leave DefaultEngine.ini
#   alone (UE falls back to engine display version, e.g. 5.7.0 — set this once).
#
# APP_CATEGORY="public.app-category.action-games"
#   When set, the script writes [/Script/MacTargetPlatform.XcodeProjectSettings]
#   AppCategory=<value> to Config/DefaultEngine.ini. UE's BaseEngine.ini already
#   defaults to public.app-category.games — only override for a different category.
#   Identifiers: https://developer.apple.com/documentation/bundleresources/information-property-list/lsapplicationcategorytype
#
# ENABLE_GAME_MODE="1"
#   1 = set LSSupportsGameMode + GCSupportsGameMode to true via PlistBuddy in
#   Build/Mac/Resources/Info.Template.plist. 0 = set both to false. Unset =
#   leave the plist's GameMode keys alone (your plist is sovereign).
#   macOS Game Mode (Sonoma 14+) gives your app elevated CPU/GPU priority when
#   a game controller is connected.
#
# CFBundleVersion (the integer Info.plist build counter) — auto-bumped by default.
# The script reads CFBUNDLE_VERSION from this file (or treats it as 0 if missing),
# pre-increments by 1, ships that value as CFBundleVersion, and writes the new
# value back here on a successful build. So with the line below, the first build
# ships CFBundleVersion=1 and this file is updated to CFBUNDLE_VERSION="1".
# Failed builds don't persist — the next build retries the same number.
CFBUNDLE_VERSION="0"
#
# To set a new baseline (e.g. pin to a CI build number, or reset the counter),
# pass --set-cfbundle-version N at the command line. The value is shipped AND
# persisted as the new baseline; subsequent auto-bump builds resume from N.
#   ./ship.sh --set-cfbundle-version 100              # next build resumes from 100
#   ./ship.sh --set-cfbundle-version "$GITHUB_RUN_NUMBER"
#   ./ship.sh --set-cfbundle-version "$BUILD_NUMBER"  # Jenkins
#
# Path A (advanced, opt-in): route CFBundleVersion through UE's PackageVersionCounter
# mechanism instead. The script seeds Build/Mac/<Project>.PackageVersionCounter and a
# project-level Build/BatchFiles/Mac/UpdateVersionAfterBuild.sh override that strips
# Epic's engine Changelist (e.g. 51494982 for EGL 5.7.4). Mutually exclusive with
# the auto-bump above.
# USE_UE_PACKAGE_VERSION_COUNTER="1"
#
# Disable individual seeds:
# SEED_MAC_INFO_TEMPLATE_PLIST="0"      # don't auto-seed Build/Mac/Resources/Info.Template.plist
# SEED_APPLE_LAUNCHSCREEN_COMPAT="0"    # don't auto-seed Build/Apple/Resources/Interface/LaunchScreen.storyboardc

# --- Distribution channels (dispatcher) ---
# MAC_DISTRIBUTION and IOS_DISTRIBUTION are the central per-platform branch
# selectors. Every downstream pipeline decision (entitlements, signing cert,
# ExportOptions method, upload tool) keys off these. See docs/configuration.md
# "Distribution channels" for the full rules and the compatibility matrix.
#
# MAC_DISTRIBUTION:
#   developer-id  (default) Direct Distribution. Developer ID Application
#                 signing, hardened runtime, notarized + stapled. Steam
#                 allowed here (and only here). Game Center NOT available —
#                 AMFI rejects com.apple.developer.game-center on
#                 Developer-ID-signed Mac apps at exec regardless of
#                 notarization.
#   app-store     Mac App Store. Apple Distribution signing, App Sandbox,
#                 Game Center allowed, Steam forbidden, uploaded via
#                 `xcrun altool` to App Store Connect. On the roadmap;
#                 currently fails fast with a clear pointer to Xcode
#                 Organizer as the workaround.
#   off           Skip Mac entirely (iOS-only run).
#
# IOS_DISTRIBUTION:
#   off           (default) Skip iOS.
#   app-store     Run the iOS pipeline. iOS has no other distribution
#                 channel in the US.
#
# MAC_DISTRIBUTION="developer-id"
# IOS_DISTRIBUTION="off"

# --- iOS pipeline (legacy aliases for the dispatcher above) ---
# These remain supported for back-compat. ENABLE_IOS=1 is equivalent to
# IOS_DISTRIBUTION=app-store. IOS_ONLY=1 is equivalent to
# "MAC_DISTRIBUTION=off + IOS_DISTRIBUTION=app-store" — it doesn't require
# SIGN_IDENTITY. Outputs land in Saved/Packages/IOS/.
# MARKETING_VERSION and CFBUNDLE_VERSION are shared across both platforms by
# default — see docs/versioning.md.
# ENABLE_IOS="0"
# IOS_ONLY="0"
# IOS_WORKSPACE="MyGame (iOS).xcworkspace"        # auto-detected if unset
# IOS_SCHEME="MyGame"                             # auto-detected from xcodebuild -list
# IOS_EXPORT_PLIST="iOS-ExportOptions.plist"      # see iOS-ExportOptions.plist.example
# IOS_APPICON_SET_NAME="AppIcon"                  # auto-detected if unset; mirrored to
#                                                 # AppIcon.appiconset inside Build/IOS/Resources/Assets.xcassets
#                                                 # if your appiconset is named differently
# IOS_MARKETING_VERSION="1.2.0"                   # iOS-only override; rare. Without it, MARKETING_VERSION applies to both platforms.

# --- iOS App Store Connect upload (xcrun altool — NOT notarytool) ---
# altool talks to App Store Connect's submission/validation API. Different
# tool, different service, different credential format from notarytool. See
# docs/configuration.md for the side-by-side comparison.
# IOS_ASC_VALIDATE="0"                            # 1 = xcrun altool --validate-app after export
# IOS_ASC_UPLOAD="0"                              # 1 = xcrun altool --upload-app (implies validate)
# IOS_ASC_API_KEY_ID="ABCD123456"                 # 10-char ASC API key ID
# IOS_ASC_API_ISSUER="00000000-0000-0000-0000-000000000000"   # ASC API issuer UUID
# IOS_ASC_API_KEY_PATH="/path/to/AuthKey_ABCD123456.p8"
#   These three values are auto-detected from Config/DefaultEngine.ini if
#   Xcode previously stored them there as AppStoreConnectKeyID,
#   AppStoreConnectIssuerID, AppStoreConnectKeyPath.

# --- Non-interactive (skip prompts) ---
# BUILD_TYPE="shipping"   # shipping | development (or s/d)
# NOTARIZE="yes"          # yes | no

# --- CI minimal config (common) ---
# In non-interactive environments, set at least:
#   DEVELOPMENT_TEAM
#   SIGN_IDENTITY
#   EXPORT_PLIST   (or generate one in-repo ahead of time)
# And if notarizing:
#   NOTARY_PROFILE
