# =============================================================================
# build.yml.example — GitHub Actions CI for macOS UE5 builds with ship.sh
#
# RENAME THIS FILE to build.yml (remove .example) to activate it.
#
# ⚠️  UNTESTED — This is a reference example, not a proven workflow.
#     Adapt it to your runner setup and test before relying on it in CI.
#
# PREREQUISITE: Self-hosted macOS runner with Unreal Engine pre-installed
# -------------------------------------------------------------------------
# GitHub-hosted macOS runners do not include Unreal Engine (30–80 GB).
# This workflow targets a self-hosted runner — a Mac Studio or Mac Mini
# registered as a GitHub Actions runner and maintained by you.
#
# To register a runner: github.com/<org>/<repo>/settings/actions/runners
#
# On the runner machine:
#   - Unreal Engine must be installed under the Epic Games Launcher path:
#     /Users/Shared/Epic Games/UE_5.x
#     ship.sh detects this path automatically.
#   - Xcode must be installed (pin a version below for reproducibility).
#
# REQUIRED GITHUB SECRETS
# -------------------------------------------------------------------------
# Set these at: github.com/<org>/<repo>/settings/secrets/actions
#
#   APPLE_DEVELOPMENT_TEAM        10-character Team ID (e.g. ABCDE12345)
#   APPLE_SIGN_IDENTITY           Full cert name: "Developer ID Application: ..."
#   APPLE_CERTIFICATE_BASE64      base64-encoded .p12 (cert + private key)
#   APPLE_CERTIFICATE_PASSWORD    Password protecting the .p12
#   APPLE_ASC_KEY_BASE64          base64-encoded App Store Connect .p8 API key
#   APPLE_ASC_KEY_ID              Key ID shown in App Store Connect
#   APPLE_ASC_ISSUER_ID           Issuer ID shown in App Store Connect
#   EXPORT_PLIST_BASE64           base64-encoded ExportOptions.plist
#                                 (base64 < ExportOptions.plist | pbcopy)
#
# NOTARYTOOL KEYCHAIN PROFILE
# -------------------------------------------------------------------------
# ship.sh uses a named keychain profile (set by NOTARY_PROFILE env var) so
# secrets never appear on the command line. This workflow creates a temporary
# profile at the start of each run and deletes it on cleanup.
# =============================================================================

name: Build, Sign & Notarize

on:
  push:
    tags:
      - 'v*'           # trigger on version tags, e.g. v1.0.0
  workflow_dispatch:   # allow manual triggers from the Actions tab

jobs:
  build:
    # Self-hosted runner label — configure this to match your runner labels.
    # See: github.com/<org>/<repo>/settings/actions/runners
    runs-on: [self-hosted, macOS]

    # Prevent concurrent builds on the same runner (UE cooks are not re-entrant)
    concurrency:
      group: ship-${{ github.ref }}
      cancel-in-progress: false

    env:
      # Passed to ship.sh via environment variables (highest priority after CLI)
      DEVELOPMENT_TEAM: ${{ secrets.APPLE_DEVELOPMENT_TEAM }}
      SIGN_IDENTITY:    ${{ secrets.APPLE_SIGN_IDENTITY }}
      NOTARY_PROFILE:   ci-notary-profile   # name used for the temp keychain profile
      BUILD_TYPE:       shipping
      NOTARIZE:         yes
      # Uncomment to also produce a DMG alongside the ZIP:
      # ENABLE_DMG:     1

    steps:
      # -----------------------------------------------------------------------
      # 1. Checkout
      # -----------------------------------------------------------------------
      - name: Checkout
        uses: actions/checkout@v4
        with:
          lfs: true          # enable if you store assets in Git LFS

      # -----------------------------------------------------------------------
      # 2. Pin Xcode version
      #    Change the path to match the Xcode version installed on your runner.
      #    List available versions: ls /Applications/Xcode*.app
      # -----------------------------------------------------------------------
      - name: Select Xcode
        run: sudo xcode-select -s /Applications/Xcode_16.2.app

      # -----------------------------------------------------------------------
      # 3. Import Developer ID certificate into a temporary keychain
      #    Creates a short-lived keychain that is deleted in the cleanup step.
      # -----------------------------------------------------------------------
      - name: Import signing certificate
        env:
          CERTIFICATE_BASE64: ${{ secrets.APPLE_CERTIFICATE_BASE64 }}
          CERTIFICATE_PASSWORD: ${{ secrets.APPLE_CERTIFICATE_PASSWORD }}
        run: |
          KEYCHAIN_PATH="$RUNNER_TEMP/ci-build.keychain"
          KEYCHAIN_PASSWORD="$(openssl rand -hex 32)"

          # Create a temporary keychain
          security create-keychain -p "$KEYCHAIN_PASSWORD" "$KEYCHAIN_PATH"
          security set-keychain-settings -lut 3600 "$KEYCHAIN_PATH"
          security unlock-keychain -p "$KEYCHAIN_PASSWORD" "$KEYCHAIN_PATH"

          # Import the certificate
          echo "$CERTIFICATE_BASE64" | base64 --decode > "$RUNNER_TEMP/certificate.p12"
          security import "$RUNNER_TEMP/certificate.p12" \
            -k "$KEYCHAIN_PATH" \
            -P "$CERTIFICATE_PASSWORD" \
            -T /usr/bin/codesign \
            -T /usr/bin/security
          rm "$RUNNER_TEMP/certificate.p12"

          # Allow codesign to access the keychain without a UI prompt
          security set-key-partition-list \
            -S apple-tool:,apple:,codesign: \
            -s -k "$KEYCHAIN_PASSWORD" "$KEYCHAIN_PATH"

          # Add to search list so codesign finds it automatically
          security list-keychains -d user -s "$KEYCHAIN_PATH" "$(security list-keychains -d user | tr -d '"')"

          # Persist the path for later steps
          echo "KEYCHAIN_PATH=$KEYCHAIN_PATH" >> "$GITHUB_ENV"
          echo "KEYCHAIN_PASSWORD=$KEYCHAIN_PASSWORD" >> "$GITHUB_ENV"

      # -----------------------------------------------------------------------
      # 4. Create notarytool keychain profile
      #    Stores App Store Connect credentials in the temporary keychain so
      #    ship.sh can call notarytool without secrets on the command line.
      # -----------------------------------------------------------------------
      - name: Create notarytool keychain profile
        env:
          ASC_KEY_BASE64:  ${{ secrets.APPLE_ASC_KEY_BASE64 }}
          ASC_KEY_ID:      ${{ secrets.APPLE_ASC_KEY_ID }}
          ASC_ISSUER_ID:   ${{ secrets.APPLE_ASC_ISSUER_ID }}
        run: |
          echo "$ASC_KEY_BASE64" | base64 --decode > "$RUNNER_TEMP/asc-key.p8"
          xcrun notarytool store-credentials "$NOTARY_PROFILE" \
            --key "$RUNNER_TEMP/asc-key.p8" \
            --key-id "$ASC_KEY_ID" \
            --issuer "$ASC_ISSUER_ID" \
            --keychain "$KEYCHAIN_PATH"
          rm "$RUNNER_TEMP/asc-key.p8"

      # -----------------------------------------------------------------------
      # 5. Write ExportOptions.plist
      #    Decoded from a base64 secret so it never lives in the repo in plain
      #    text (though ExportOptions.plist.example is safe to commit — it
      #    contains no credentials, only configuration).
      # -----------------------------------------------------------------------
      - name: Write ExportOptions.plist
        env:
          EXPORT_PLIST_BASE64: ${{ secrets.EXPORT_PLIST_BASE64 }}
        run: |
          PLIST_PATH="$RUNNER_TEMP/ExportOptions.plist"
          echo "$EXPORT_PLIST_BASE64" | base64 --decode > "$PLIST_PATH"
          echo "EXPORT_PLIST=$PLIST_PATH" >> "$GITHUB_ENV"

      # -----------------------------------------------------------------------
      # 6. Build, sign, and notarize
      # -----------------------------------------------------------------------
      - name: Ship
        run: ./ship.sh

      # -----------------------------------------------------------------------
      # 7. Upload artifacts
      # -----------------------------------------------------------------------
      - name: Upload ZIP
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: ${{ github.ref_name }}-zip
          path: Build/*.zip
          if-no-files-found: warn

      - name: Upload DMG
        if: env.ENABLE_DMG == '1'
        uses: actions/upload-artifact@v4
        with:
          name: ${{ github.ref_name }}-dmg
          path: Build/*.dmg
          if-no-files-found: warn

      # -----------------------------------------------------------------------
      # 8. Cleanup — always runs, even on failure
      #    Removes the temporary keychain so credentials don't persist on the
      #    runner between jobs.
      # -----------------------------------------------------------------------
      - name: Cleanup keychain
        if: always()
        run: |
          if [[ -n "${KEYCHAIN_PATH:-}" ]]; then
            # Remove the temporary keychain from the search list and delete it
            REMAINING=$(security list-keychains -d user | tr -d '"' | grep -v "$KEYCHAIN_PATH" || true)
            security list-keychains -d user -s $REMAINING
            security delete-keychain "$KEYCHAIN_PATH" || true
          fi
