# -----------------------------------------------------------------------------
# ship.sh — .env template (preset: mas-ios)
#
# Mac App Store + iOS App Store build. Both channels use xcodebuild's automatic
# provisioning + xcrun altool for upload. CFBUNDLE_VERSION is shared across
# both platforms. Game Center is allowed on both channels.
#
# Note: xcrun altool (App Store Connect) is NOT xcrun notarytool (notarization).
# Different tools, different services, different credential format.
#
# Copy to .env, fill in the required values below, run ship.sh.
# Full reference: docs/configuration.md
# -----------------------------------------------------------------------------

# --- Preset values (baked in for mas-ios) ---
MAC_DISTRIBUTION="app-store"
IOS_DISTRIBUTION="app-store"

# --- Required for non-interactive runs ---
# DEVELOPMENT_TEAM="ABCDE12345"
# MAS_EXPORT_PLIST="/absolute/path/to/MAS-ExportOptions.plist"
# IOS_EXPORT_PLIST="/absolute/path/to/iOS-ExportOptions.plist"
# XCODE_SCHEME="MyGame"
# IOS_SCHEME="MyGame"
# BUILD_TYPE="shipping"

# --- App Store Connect upload (shared key for Mac + iOS) ---
# MAS_ASC_VALIDATE="1"
# MAS_ASC_UPLOAD="1"
# IOS_ASC_VALIDATE="1"
# IOS_ASC_UPLOAD="1"
# ASC_API_KEY_ID="ABCD123456"
# ASC_API_ISSUER="00000000-0000-0000-0000-000000000000"
# ASC_API_KEY_PATH="/path/to/AuthKey_ABCD123456.p8"

# --- Game Center (optional; allowed on both channels) ---
# ENABLE_GAME_CENTER="1"

# Auto-bumped Info.plist build counter; persisted to this file on success.
CFBUNDLE_VERSION="0"
