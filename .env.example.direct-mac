# -----------------------------------------------------------------------------
# ship.sh — .env template (preset: direct-mac)
#
# Direct Distribution build: Developer ID signed, hardened runtime, notarized,
# DMG packaged for direct download / drag-to-install. Game Center is not
# available on this channel (AMFI rejects it on Developer-ID-signed Mac apps).
#
# Copy to .env, fill in the required signing values below, run ship.sh.
# Full reference: docs/configuration.md
# -----------------------------------------------------------------------------

# --- Preset values (baked in for direct-mac) ---
MAC_DISTRIBUTION="developer-id"
ENABLE_STEAM="0"
ENABLE_DMG="1"
NOTARIZE="yes"

# --- Required for non-interactive runs ---
# DEVELOPMENT_TEAM="ABCDE12345"
# SIGN_IDENTITY="Developer ID Application: Your Company (ABCDE12345)"
# NOTARY_PROFILE="MyNotaryProfile"
# EXPORT_PLIST="/absolute/path/to/ExportOptions.plist"
# XCODE_SCHEME="MyGame"
# BUILD_TYPE="shipping"

# --- DMG packaging (commonly customized) ---
# DMG_NAME="MyGame.dmg"
# DMG_VOLUME_NAME="MyGame"
# DMG_OUTPUT_DIR="Build"
# FANCY_DMG="0"

# Auto-bumped Info.plist build counter; persisted to this file on success.
CFBUNDLE_VERSION="0"
